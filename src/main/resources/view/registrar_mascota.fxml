<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cr.tec.bd.crv.controller.RegistrarMascotaController">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <VBox alignment="CENTER" spacing="12.0" maxWidth="430" styleClass="card">
        <Label text="Registrar Mascota" styleClass="titulo"/>
        <Label text="Ingrese los datos de la mascota" styleClass="subtitulo"/>

        <TextField fx:id="txtNombre" promptText="Nombre" maxWidth="320"/>
        <TextField fx:id="txtRaza" promptText="Raza" maxWidth="320"/>
        <ComboBox fx:id="cbTipo" promptText="Tipo de mascota" maxWidth="320"/>
        <TextField fx:id="txtColor" promptText="Color" maxWidth="320"/>
        <TextArea fx:id="txtNotas" promptText="Notas adicionales" maxWidth="320" prefRowCount="4"/>

        <Button text="Guardar"
                onAction="#guardarMascota"
                maxWidth="320"/>

        <Button text="Volver al menú"
                onAction="#volverMenu"
                maxWidth="320"
                styleClass="button-secundario"/>

        <Label fx:id="lblMensaje" text="" styleClass="mensaje"/>
    </VBox>
</VBox>