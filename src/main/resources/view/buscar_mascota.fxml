<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cr.tec.bd.crv.controller.BuscarMascotaController">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <VBox alignment="CENTER" spacing="12.0" maxWidth="430" styleClass="card">
        <Label text="Buscar Mascota" styleClass="titulo"/>
        <Label text="Busque por nombre, raza o color" styleClass="subtitulo"/>

        <TextField fx:id="txtBusqueda" promptText="Ingrese criterio de búsqueda" maxWidth="320"/>

        <Button text="Buscar"
                onAction="#buscarMascota"
                maxWidth="320"/>

        <Button text="Volver al menú"
                onAction="#volverMenu"
                maxWidth="320"
                styleClass="button-secundario"/>

        <Label fx:id="lblResultado" text="" styleClass="mensaje"/>
    </VBox>
</VBox>