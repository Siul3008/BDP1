<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cr.tec.bd.crv.controller.MenuController">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <VBox alignment="CENTER" spacing="15.0" maxWidth="420" styleClass="card">
        <Label text="Sistema de Gestión de Mascotas" styleClass="titulo"/>
        <Label text="Menú principal" styleClass="subtitulo"/>

        <Button text="Registrar Mascota"
                onAction="#abrirRegistrarMascota"
                maxWidth="260"/>

        <Button text="Buscar Mascota"
                onAction="#abrirBuscarMascota"
                maxWidth="260"/>

        <Button text="Lista de Mascotas"
                onAction="#abrirListaMascotas"
                maxWidth="260"/>

        <Button text="Probar conexión BD"
                onAction="#probarConexion"
                maxWidth="260"
                styleClass="button-secundario"/>

        <Button text="Salir"
                onAction="#salirSistema"
                maxWidth="260"
                styleClass="button-peligro"/>
    </VBox>
</VBox>