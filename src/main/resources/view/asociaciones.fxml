<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cr.tec.bd.crv.controller.AssociationController"
            styleClass="screen">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="top-bar">
            <padding><Insets top="18" right="24" bottom="10" left="24"/></padding>
            <ImageView fitHeight="52" fitWidth="52" preserveRatio="true">
                <image><Image url="@/images/logo.png"/></image>
            </ImageView>
            <VBox spacing="2.0">
                <Label text="Asociaciones" styleClass="brand-title"/>
                <Label text="Gestión administrativa de organizaciones" styleClass="brand-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Volver al panel admin" onAction="#volverAdmin" styleClass="ghost-button"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="18.0">
            <padding><Insets top="10" right="24" bottom="24" left="24"/></padding>
            <HBox spacing="18.0">
                <VBox spacing="12.0" HBox.hgrow="ALWAYS" styleClass="card form-card">
                    <Label text="Registrar asociación" styleClass="title-lg"/>
                    <GridPane hgap="14.0" vgap="14.0">
                        <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Nombre" styleClass="field-label"/>
                            <TextField fx:id="txtNombreAsociacion" promptText="Nombre de la asociación"/>
                        </VBox>
                    </GridPane>
                    <HBox spacing="10.0">
                        <Button text="Guardar asociación" onAction="#guardarAsociacion" styleClass="primary-button">
                            <tooltip><Tooltip text="Registra la asociación en la base de datos."/></tooltip>
                        </Button>
                        <Button text="Limpiar" onAction="#limpiarFormulario" styleClass="secondary-button">
                            <tooltip><Tooltip text="Borra los datos escritos."/></tooltip>
                        </Button>
                    </HBox>
                    <Label fx:id="lblMensajeAsociacion" text="" wrapText="true" styleClass="message-label"/>
                </VBox>
                <VBox spacing="12.0" prefWidth="420" styleClass="card result-card">
                    <Label text="Asociaciones registradas" styleClass="section-title"/>
                    <TableView prefHeight="320">
                        <columns>
                            <TableColumn text="Nombre" prefWidth="180"/>
                            <TableColumn text="Estado" prefWidth="120"/>
                            <TableColumn text="Observaciones" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
