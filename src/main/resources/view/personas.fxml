<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cr.tec.bd.crv.controller.ModuloPlantillaController"
            styleClass="screen">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="top-bar">
            <padding><Insets top="18" right="24" bottom="10" left="24"/></padding>
            <ImageView fitHeight="52" fitWidth="52" preserveRatio="true"><image><Image url="@/images/logo.png"/></image></ImageView>
            <Label text="Personas" styleClass="brand-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Volver al menú" onAction="#volverMenu" styleClass="ghost-button">
                <tooltip><Tooltip text="Regresa al menú principal."/></tooltip>
            </Button>
        </HBox>
    </top>
    <center>
        <VBox spacing="18.0">
            <padding><Insets top="10" right="24" bottom="24" left="24"/></padding>
            <HBox spacing="18.0">
                <VBox spacing="12.0" HBox.hgrow="ALWAYS" styleClass="card form-card">
                    <Label text="Registro de persona" styleClass="title-lg"/>
                    <GridPane hgap="14.0" vgap="14.0">
                        <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0"><Label text="Primer nombre" styleClass="field-label"/><TextField promptText="Primer nombre"/></VBox>
                        <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="0"><Label text="Segundo nombre" styleClass="field-label"/><TextField promptText="Segundo nombre"/></VBox>
                        <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="1"><Label text="Primer apellido" styleClass="field-label"/><TextField promptText="Primer apellido"/></VBox>
                        <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="1"><Label text="Segundo apellido" styleClass="field-label"/><TextField promptText="Segundo apellido"/></VBox>
                        <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="2"><Label text="Correo" styleClass="field-label"/><TextField promptText="correo@ejemplo.com"/></VBox>
                        <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="2"><Label text="Teléfono" styleClass="field-label"/><TextField promptText="Número principal"/></VBox>
                        <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="3"><Label text="Rol" styleClass="field-label"/><ComboBox promptText="Seleccione una opción"/></VBox>
                        <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="3"><Label text="Provincia" styleClass="field-label"/><ComboBox promptText="Seleccione una opción"/></VBox>
                    </GridPane>
                    <HBox spacing="10.0">
                        <Button text="Guardar persona" onAction="#mostrarAviso" styleClass="primary-button">
                            <tooltip><Tooltip text="Guarda la información de la persona."/></tooltip>
                        </Button>
                        <Button text="Ver reportes" onAction="#mostrarAviso" styleClass="secondary-button">
                            <tooltip><Tooltip text="Muestra reportes relacionados con personas."/></tooltip>
                        </Button>
                    </HBox>
                </VBox>
                <VBox spacing="12.0" prefWidth="420" styleClass="card result-card">
                    <Label text="Listado de personas" styleClass="section-title"/>
                    <TableView prefHeight="340">
                        <columns>
                            <TableColumn text="Nombre" prefWidth="170"/>
                            <TableColumn text="Rol" prefWidth="110"/>
                            <TableColumn text="Correo" prefWidth="140"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>

