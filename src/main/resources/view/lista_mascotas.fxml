<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cr.tec.bd.crv.controller.ListaMascotasController"
            styleClass="screen">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets top="18" right="24" bottom="10" left="24"/>
            </padding>
            <ImageView fitHeight="52" fitWidth="52" preserveRatio="true">
                <image>
                    <Image url="@/images/logo.png"/>
                </image>
            </ImageView>
            <VBox spacing="2.0">
                <Label text="Lista de mascotas" styleClass="brand-title"/>
                <Label text="Tabla general de registros" styleClass="brand-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Nuevo registro" onAction="#abrirRegistro" styleClass="secondary-button"/>
            <Button text="Estadísticas" onAction="#abrirEstadisticas" styleClass="ghost-button"/>
            <Button text="Volver al menú" onAction="#volverMenu" styleClass="ghost-button"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="18.0">
            <padding>
                <Insets top="10" right="24" bottom="24" left="24"/>
            </padding>
            <HBox spacing="16.0">
                <VBox spacing="6.0" prefWidth="220" styleClass="card mini-stat">
                    <Label text="4" styleClass="stat-number"/>
                    <Label text="Registros de ejemplo" styleClass="subtle-text"/>
                </VBox>
                <VBox spacing="6.0" prefWidth="220" styleClass="card mini-stat">
                    <Label text="2" styleClass="stat-number"/>
                    <Label text="Mascotas en adopción" styleClass="subtle-text"/>
                </VBox>
                <VBox spacing="6.0" prefWidth="220" styleClass="card mini-stat">
                    <Label text="1" styleClass="stat-number"/>
                    <Label text="Mascotas perdidas" styleClass="subtle-text"/>
                </VBox>
            </HBox>
            <VBox spacing="12.0" styleClass="card result-card">
                <Label text="Registros consultados" styleClass="title-lg"/>
                <TableView fx:id="tablaMascotas" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
                        <TableColumn fx:id="colNombre" text="Nombre" prefWidth="160"/>
                        <TableColumn fx:id="colTipo" text="Tipo" prefWidth="130"/>
                        <TableColumn fx:id="colRaza" text="Raza" prefWidth="180"/>
                        <TableColumn fx:id="colColor" text="Color" prefWidth="130"/>
                        <TableColumn fx:id="colEstado" text="Estado" prefWidth="180"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>

