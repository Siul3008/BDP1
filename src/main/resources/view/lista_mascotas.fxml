<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="cr.tec.bd.crv.controller.ListaMascotasController">

    <top>
        <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="Lista de Mascotas" styleClass="titulo"/>
            <Label text="Visualización general de registros" styleClass="subtitulo"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="15.0" alignment="CENTER">
            <padding>
                <Insets top="10" right="20" bottom="20" left="20"/>
            </padding>

            <TableView fx:id="tablaMascotas" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="140"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="120"/>
                    <TableColumn fx:id="colRaza" text="Raza" prefWidth="160"/>
                    <TableColumn fx:id="colColor" text="Color" prefWidth="120"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="180"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="12.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="20" bottom="20" left="20"/>
            </padding>

            <Button text="Volver al menú"
                    onAction="#volverMenu"
                    styleClass="button-secundario"
                    maxWidth="200"/>
        </HBox>
    </bottom>
</BorderPane>